# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nalargizi?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/nalargizi?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-in-production"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Gemini AI
GEMINI_API_KEY="your-gemini-api-key-here"

# App
PORT=3000
NODE_ENV=development
API_PREFIX=api/v1
CORS_ORIGINS="http://localhost:3000,http://localhost:8000"

# Google OAuth
GOOGLE_CLIENT_ID_WEB="your-google-client-id-web.apps.googleusercontent.com"
GOOGLE_CLIENT_ID_ANDROID="your-google-client-id-android.apps.googleusercontent.com"
GOOGLE_CLIENT_ID_IOS="your-google-client-id-ios.apps.googleusercontent.com"

